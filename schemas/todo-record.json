{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "todo-record",
  "title": "To-Do Record",
  "description": "One line in data/todos/active.jsonl. Tracks personal action items for Glen.",
  "type": "object",
  "required": ["id", "ts", "status", "text", "priority", "trigger"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique to-do ID in format todo-YYYY-MM-DD-NNN",
      "pattern": "^todo-\\d{4}-\\d{2}-\\d{2}-\\d{3}$"
    },
    "ts": {
      "type": "string",
      "description": "ISO 8601 timestamp with timezone offset when to-do was created"
    },
    "status": {
      "type": "string",
      "enum": ["active", "completed"],
      "description": "Current to-do state"
    },
    "text": {
      "type": "string",
      "description": "The to-do description"
    },
    "priority": {
      "type": "string",
      "enum": ["high", "normal", "low"],
      "description": "Priority level"
    },
    "trigger": {
      "type": "string",
      "enum": ["manual", "recurring"],
      "description": "How the to-do was created"
    },
    "due_date": {
      "type": ["string", "null"],
      "description": "Due date in YYYY-MM-DD format, or null if no due date",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "category": {
      "type": ["string", "null"],
      "enum": ["business", "personal", "marketing", null],
      "description": "Category for grouping"
    },
    "recurring": {
      "type": ["string", "null"],
      "enum": ["daily", "weekly", "weekdays", null],
      "description": "Recurrence schedule, or null for one-off to-dos"
    },
    "completed_at": {
      "type": ["string", "null"],
      "description": "ISO 8601 timestamp when to-do was completed"
    },
    "linked_task_id": {
      "type": ["string", "null"],
      "description": "Task ID if this to-do spawned a Claude task (e.g., task-2026-03-23-001)"
    }
  },
  "additionalProperties": false
}
