{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "triage-record",
  "title": "Email Triage Record",
  "description": "One line in a triage run file (data/triage/YYYY-MM-DDTHHMM.jsonl). One record per email.",
  "type": "object",
  "required": ["message_id", "thread_id", "from", "subject", "received", "priority"],
  "properties": {
    "message_id": {
      "type": "string",
      "description": "Gmail message ID"
    },
    "thread_id": {
      "type": "string",
      "description": "Gmail thread ID"
    },
    "from": {
      "type": "string",
      "description": "Sender email address"
    },
    "from_name": {
      "type": "string",
      "description": "Sender display name"
    },
    "subject": {
      "type": "string",
      "description": "Email subject line"
    },
    "received": {
      "type": "string",
      "description": "ISO 8601 timestamp when email was received"
    },
    "category": {
      "type": "string",
      "enum": ["client", "team", "sales", "admin", "noise"],
      "description": "Sender/content category"
    },
    "priority": {
      "type": "string",
      "enum": ["urgent", "needs-response", "informational", "low-priority"],
      "description": "Triage priority bucket"
    },
    "starred": {
      "type": "boolean",
      "description": "Whether email is starred in Gmail (Glen's action queue)"
    },
    "has_attachments": {
      "type": "boolean",
      "description": "Whether email has file attachments"
    },
    "snippet": {
      "type": "string",
      "description": "First 200 chars of email body text",
      "maxLength": 200
    },
    "action_items": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Detected actionable items from email content"
    },
    "suggested_action": {
      "type": "string",
      "enum": ["draft-reply", "review-attachment", "forward-to-team", "archive", "none"],
      "description": "Claude's recommended next step"
    }
  },
  "additionalProperties": false
}
